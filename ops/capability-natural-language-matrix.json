{
  "matrix_id": "spark_capability_natural_language_routes_v1",
  "purpose": "Golden natural-language cases for separating Spark capability proposals from ordinary app builds.",
  "guardrails": [
    "capability proposals are not normal Spawner app builds",
    "normal dashboards and user tools still build",
    "proposal packets remain proposal_plan_only",
    "connector and workflow capabilities start behind dry-run harnesses",
    "voice-specific phrases may route to the voice surface while still avoiding app-build drift"
  ],
  "cases": [
    {
      "id": "install_voice_self",
      "prompt": "lets make today about improving your capabilities... can you install a voice to yourself?",
      "expected_telegram_build_intent": false,
      "expected_telegram_self_improvement_goal_contains": ["install a voice"],
      "expected_builder_capability_query": true,
      "expected_builder_route_mode": "voice_io",
      "expected_builder_target_system": "Spark Voice",
      "expected_proposal_route": "capability_connector",
      "expected_connector_key": "voice"
    },
    {
      "id": "build_for_you_email",
      "prompt": "Okay let's build this for you, Spark: a way to read my emails and summarize them.",
      "expected_telegram_build_intent": false,
      "expected_telegram_self_improvement_goal_contains": ["read my emails"],
      "expected_builder_capability_query": true,
      "expected_builder_route_mode": "capability_improvement",
      "expected_builder_target_system": "Spark Intelligence Builder",
      "expected_proposal_route": "capability_connector",
      "expected_connector_key": "email"
    },
    {
      "id": "build_you_email_reader",
